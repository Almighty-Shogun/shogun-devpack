<idea-plugin>
    <id>ms.shogun.devpack</id>
    <name>Shogun's DevPack</name>
    <vendor email="alm1ghtyshogun1998@gmail.com" url="https://shogun.ms">Shogun</vendor>

    <depends>com.intellij.modules.lang</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <resource-bundle>messages.MyMessageBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="ShogunDevPack.Notifications" displayType="BALLOON" key="notification.group.name"/>

        <applicationService serviceImplementation="ms.shogun.devpack.settings.ShogunDevPackSettings"/>

        <applicationConfigurable
            id="ms.shogun.devpack.settings"
            instance="ms.shogun.devpack.settings.ShogunDevPackConfigurable"
            bundle="messages.MyMessageBundle"
            key="settings.display-name"/>

        <applicationConfigurable
            id="ms.shogun.devpack.settings.code-share"
            parentId="ms.shogun.devpack.settings"
            instance="ms.shogun.devpack.settings.codeShare.CodeShareConfigurable"
            bundle="messages.MyMessageBundle"
            key="settings.code-share.display-name"/>

        <applicationConfigurable
            id="ms.shogun.devpack.settings.code-share.pastebin"
            parentId="ms.shogun.devpack.settings.code-share"
            instance="ms.shogun.devpack.settings.codeShare.PastebinConfigurable"
            bundle="messages.MyMessageBundle"
            key="settings.pastebin.display-name"/>

        <applicationConfigurable
            id="ms.shogun.devpack.settings.code-share.github-gist"
            parentId="ms.shogun.devpack.settings.code-share"
            instance="ms.shogun.devpack.settings.codeShare.GitHubGistConfigurable"
            bundle="messages.MyMessageBundle"
            key="settings.github-gist.display-name"/>

        <applicationConfigurable
            id="ms.shogun.devpack.settings.code-share.custom-server"
            parentId="ms.shogun.devpack.settings.code-share"
            instance="ms.shogun.devpack.settings.codeShare.CodeShareCustomServerConfigurable"
            bundle="messages.MyMessageBundle"
            key="settings.custom-server.display-name"/>

        <applicationConfigurable
            id="ms.shogun.devpack.settings.code-shot"
            parentId="ms.shogun.devpack.settings"
            instance="ms.shogun.devpack.settings.codeShot.CodeShotConfigurable"
            bundle="messages.MyMessageBundle"
            key="settings.code-shot.display-name"/>

        <applicationConfigurable
            id="ms.shogun.devpack.settings.code-shot.freeimage-host"
            parentId="ms.shogun.devpack.settings.code-shot"
            instance="ms.shogun.devpack.settings.codeShot.FreeimageHostConfigurable"
            bundle="messages.MyMessageBundle"
            key="settings.freeimage-host.display-name"/>

        <applicationConfigurable
            id="ms.shogun.devpack.settings.code-shot.imgbb"
            parentId="ms.shogun.devpack.settings.code-shot"
            instance="ms.shogun.devpack.settings.codeShot.ImgBbConfigurable"
            bundle="messages.MyMessageBundle"
            key="settings.imgbb.display-name"/>

        <applicationConfigurable
            id="ms.shogun.devpack.settings.code-shot.custom-server"
            parentId="ms.shogun.devpack.settings.code-shot"
            instance="ms.shogun.devpack.settings.codeShot.CodeShotCustomServerConfigurable"
            bundle="messages.MyMessageBundle"
            key="settings.custom-server.display-name"/>

        <applicationConfigurable
            id="ms.shogun.devpack.settings.ai-terminal"
            parentId="ms.shogun.devpack.settings"
            instance="ms.shogun.devpack.settings.ai.AiTerminalConfigurable"
            bundle="messages.MyMessageBundle"
            key="settings.ai-terminal.display-name"/>

        <applicationConfigurable
            id="ms.shogun.devpack.settings.ai-terminal.codex"
            parentId="ms.shogun.devpack.settings.ai-terminal"
            instance="ms.shogun.devpack.settings.ai.codex.CodexConfigurable"
            bundle="messages.MyMessageBundle"
            key="settings.codex.display-name"/>

        <projectConfigurable
            id="ms.shogun.devpack.project.settings"
            parentId="ms.shogun.devpack.settings.ai-terminal.codex"
            instance="ms.shogun.devpack.settings.ai.codex.CodexProjectConfigurable"
            bundle="messages.MyMessageBundle"
            key="settings.project.display-name"/>

        <applicationConfigurable
            id="ms.shogun.devpack.settings.ai-terminal.claude"
            parentId="ms.shogun.devpack.settings.ai-terminal"
            instance="ms.shogun.devpack.settings.ai.claude.ClaudeConfigurable"
            bundle="messages.MyMessageBundle"
            key="settings.claude.display-name"/>

        <projectConfigurable
            id="ms.shogun.devpack.project.settings.claude"
            parentId="ms.shogun.devpack.settings.ai-terminal.claude"
            instance="ms.shogun.devpack.settings.ai.claude.ClaudeProjectConfigurable"
            bundle="messages.MyMessageBundle"
            key="settings.project.display-name"/>

        <toolWindow
            id="Codex"
            anchor="right"
            doNotActivateOnStart="true"
            icon="/icons/ai/codex.svg"
            factoryClass="ms.shogun.devpack.ai.codex.CodexToolWindowFactory"/>

        <toolWindow
            id="Claude"
            anchor="right"
            doNotActivateOnStart="true"
            icon="/icons/ai/claude.svg"
            factoryClass="ms.shogun.devpack.ai.claude.ClaudeToolWindowFactory"/>

        <internalFileTemplate name="Service"/>
        <internalFileTemplate name="JSON Model"/>
        <internalFileTemplate name="Remote Command"/>
        <internalFileTemplate name="Console Command"/>
        <internalFileTemplate name="Dependency Injection"/>

        <internalFileTemplate name="JSON"/>
        <internalFileTemplate name="Markdown"/>

        <internalFileTemplate name="CODEOWNERS"/>
        <internalFileTemplate name="LICENSE"/>
        <internalFileTemplate name="Git Ignore"/>
        <internalFileTemplate name="Git Keep"/>

        <internalFileTemplate name="EditorConfig"/>

        <internalFileTemplate name="Vue Store"/>
        <internalFileTemplate name="Vue Component"/>
        <internalFileTemplate name="Vue Composable"/>
        <internalFileTemplate name="Vue Component Bundle"/>

        <bundledColorScheme id="Shogun's DevPack: Dark color scheme" path="colors/dark_color_scheme.xml"/>

        <themeProvider id="ShogunDevPackDark" path="/themes/dark_theme.json" targetUi="islands"/>
    </extensions>

    <actions>
        <group id="ShogunDevPack.MainMenu" popup="true" icon="/icons/logo/app-icon-16.svg">
            <add-to-group group-id="MainToolbarRight" anchor="before" relative-to-action="SearchEverywhere"/>

            <group id="ShogunDevPack.ShiftTabMenu" popup="true" icon="/icons/grid.svg">
                <action
                    id="ShogunDevPack.ShiftTab.Up"
                    class="ms.shogun.devpack.shiftTab.ShiftTabUpAction"
                    icon="/icons/shift-tab-up.svg">

                    <keyboard-shortcut first-keystroke="ctrl NUMPAD8" keymap="$default"/>
                </action>

                <action
                    id="ShogunDevPack.ShiftTab.Right"
                    class="ms.shogun.devpack.shiftTab.ShiftTabRightAction"
                    icon="/icons/shift-tab-right.svg">

                    <keyboard-shortcut first-keystroke="ctrl NUMPAD6" keymap="$default"/>
                </action>

                <action
                    id="ShogunDevPack.ShiftTab.Left"
                    class="ms.shogun.devpack.shiftTab.ShiftTabLeftAction"
                    icon="/icons/shift-tab-left.svg">

                    <keyboard-shortcut first-keystroke="ctrl NUMPAD4" keymap="$default"/>
                </action>

                <action
                    id="ShogunDevPack.ShiftTab.Down"
                    class="ms.shogun.devpack.shiftTab.ShiftTabDownAction"
                    icon="/icons/shift-tab-down.svg">

                    <keyboard-shortcut first-keystroke="ctrl NUMPAD2" keymap="$default"/>
                </action>
            </group>

            <separator/>

            <action
                id="ShogunDevPack.CodeShot"
                class="ms.shogun.devpack.codeShot.CodeShotAction"
                icon="/icons/file-image.svg">

                <keyboard-shortcut first-keystroke="ctrl NUMPAD5" keymap="$default"/>
            </action>

            <action
                id="ShogunDevPack.CodeShare.Upload"
                class="ms.shogun.devpack.codeShare.UploadCodeAction"
                icon="/icons/file-code.svg">

                <keyboard-shortcut first-keystroke="ctrl NUMPAD9" keymap="$default"/>
            </action>

            <separator/>

            <action
                id="ShogunDevPack.Codex.Toggle"
                class="ms.shogun.devpack.ai.codex.ToggleCodexToolWindowAction"
                icon="/icons/ai/codex-16.svg">

                <keyboard-shortcut first-keystroke="ctrl NUMPAD1" keymap="$default"/>
            </action>

            <action
                id="ShogunDevPack.Claude.Toggle"
                class="ms.shogun.devpack.ai.claude.ToggleClaudeToolWindowAction"
                icon="/icons/ai/claude-16.svg">

                <keyboard-shortcut first-keystroke="ctrl NUMPAD3" keymap="$default"/>
            </action>

            <separator/>

            <action
                id="ShogunDevPack.About"
                class="ms.shogun.devpack.AboutAction"
                icon="/icons/logo/app-icon-16.svg"/>
        </group>

        <action
            id="ShogunDevPack.CodeShare.Upload.Context"
            class="ms.shogun.devpack.codeShare.UploadCodeAction"
            icon="/icons/file-code.svg">

            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>

        <group id="ShogunDevPack.CustomFiles" popup="true" icon="/icons/logo/app-icon-16.svg">
            <add-to-group group-id="NewGroup" anchor="first"/>

            <action
                id="ShogunDevPack.Files.CSharp"
                class="ms.shogun.devpack.files.actions.CSharpFileAction"
                icon="/icons/files/csharp.svg"/>

            <action
                id="ShogunDevPack.Files.Vue"
                class="ms.shogun.devpack.files.actions.VueFileAction"
                icon="/icons/files/vue.svg"/>

            <separator/>

            <action
                id="ShogunDevPack.Files.Json"
                class="ms.shogun.devpack.files.actions.JsonFileAction"
                icon="/icons/files/json.svg"/>

            <action
                id="ShogunDevPack.Files.Markdown"
                class="ms.shogun.devpack.files.actions.MarkdownFileAction"
                icon="/icons/files/markdown.svg"/>

            <separator/>

            <!--suppress PluginXmlCapitalization -->
            <action
                id="ShogunDevPack.Files.EditorConfig"
                class="ms.shogun.devpack.files.actions.EditorConfigFileAction"
                icon="/icons/files/editorconfig.svg"/>

            <separator/>

            <action
                id="ShogunDevPack.Files.Codeowners"
                class="ms.shogun.devpack.files.actions.CodeownersFileAction"
                icon="/icons/files/codeowners.svg"/>

            <action
                id="ShogunDevPack.Files.License"
                class="ms.shogun.devpack.files.actions.LicenseFileAction"
                icon="/icons/files/license.svg"/>

            <!--suppress PluginXmlCapitalization -->
            <action
                id="ShogunDevPack.Files.GitIgnore"
                class="ms.shogun.devpack.files.actions.GitIgnoreFileAction"
                icon="/icons/files/gitignore.svg"/>

            <!--suppress PluginXmlCapitalization -->
            <action
                id="ShogunDevPack.Files.GitKeep"
                class="ms.shogun.devpack.files.actions.GitKeepFileAction"
                icon="/icons/files/git.svg"/>
        </group>
    </actions>
</idea-plugin>
